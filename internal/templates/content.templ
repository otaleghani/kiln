				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="h-5 w-5 text-foreground"
				id="toc-icon"
			>
				<path d="M16 5H3"></path>
				<path d="M16 12H3"></path>
				<path d="M16 19H3"></path>
				<path d="M21 5h.01"></path>
				<path d="M21 12h.01"></path>
				<path d="M21 19h.01"></path>
			</svg>
		</button>
	</div>
}

// SimpleLocalGraphButton renders the local graph icon button for the simple layout header.
templ SimpleLocalGraphButton(labels *i18n.Labels) {
	<div>
		<button
			id="local-graph-button"
			aria-label={ labels.LocalGraph }
			title={ labels.LocalGraph }
			class="cursor-pointer p-1 rounded hover:bg-hover transition-colors"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="w-5 h-5 text-foreground"
				id="local-graph-icon"
			>
				<circle cx="12" cy="4.5" r="2.5"></circle>
				<path d="m10.2 6.3-3.9 3.9"></path>
				<circle cx="4.5" cy="12" r="2.5"></circle>
				<path d="M7 12h10"></path>
				<circle cx="19.5" cy="12" r="2.5"></circle>
				<path d="m13.8 17.7 3.9-3.9"></path>
				<circle cx="12" cy="19.5" r="2.5"></circle>
			</svg>
		</button>
	</div>
}

// SimpleTOCContainer renders the overlay modal for the TOC in the simple layout.
templ SimpleTOCContainer(data *PageData) {
	<div
		class="fixed inset-0 z-40 bg-background pb-4 hidden overflow-scroll p-4 md:p-0"
		id="toc-wrapper"
	>
		<div class="max-w-prose mx-auto w-full rounded-xl border border-sidebar-border p-6 mt-20 md:mt-24">
			if !data.Site.DisableTOC {
				<div id="toc-container">
					if data.TOC != "" {
						<header class="flex justify-between items-center py-2 border-b border-sidebar-border mb-4">
							<span class="font-bold">{ data.Site.Labels.TableOfContents }</span>
						</header>
						<div>
							@templ.Raw(data.TOC)
						</div>
						<script>
							if (document.getElementById("toc-container")) {
								const links = document.getElementById("toc-container").querySelectorAll("a");
								links.forEach((link) => {
									link.addEventListener("click", function() {
										window.toggleTOC();
									});
								});
							}
						</script>
					}
				</div>
			}
		</div>
	</div>
}

// SimpleLocalGraphContainer renders the overlay modal for the local graph in the simple layout.
templ SimpleLocalGraphContainer() {
	<div
		class="fixed inset-0 z-40 bg-background pb-4 hidden overflow-scroll p-4 md:p-0"
		id="local-graph-wrapper"
	>
		<div class="max-w-prose mx-auto w-full rounded-xl border border-sidebar-border p-6 mt-20 md:mt-24">
			<div id="local-graph-container"></div>
		</div>
	</div>
}

// SimpleBacklinksButton renders the backlinks icon button for the simple layout header.
templ SimpleBacklinksButton(labels *i18n.Labels) {
	<div>
		<button
			id="backlinks-button"
			aria-label={ labels.Backlinks }
			title={ labels.Backlinks }
			class="cursor-pointer p-1 rounded hover:bg-hover transition-colors"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="w-5 h-5 text-foreground"
				id="backlinks-icon"
			>
				<path d="M9 17H7A5 5 0 0 1 7 7h2"></path>
				<path d="M15 7h2a5 5 0 1 1 0 10h-2"></path>
				<line x1="8" x2="16" y1="12" y2="12"></line>
			</svg>
		</button>
	</div>
}

// SimpleBacklinksContainer renders the overlay modal for backlinks in the simple layout.
templ SimpleBacklinksContainer(data *PageData) {
	<div
		class="fixed inset-0 z-40 bg-background pb-4 hidden overflow-scroll p-4 md:p-0"
		id="backlinks-wrapper"
	>
		<div class="max-w-prose mx-auto w-full rounded-xl border border-sidebar-border p-6 mt-20 md:mt-24">
			if !data.Site.DisableBacklinks && len(data.Backlinks) > 0 {
				<div id="backlinks-container">
					<header class="flex justify-between items-center py-2 border-b border-sidebar-border mb-4">
						<span class="font-bold">{ data.Site.Labels.Backlinks }</span>
					</header>
					<ul class="flex flex-col gap-1">
						for _, bl := range data.Backlinks {
							<li>
								<a
									href={ templ.SafeURL(bl.WebPath) }
									class="text-sm hover:text-accent transition-colors"
								>
									{ bl.Name }
								</a>
							</li>
						}
					</ul>
				</div>
			}
		</div>
	</div>
}

// SimpleMenuButton renders the hamburger menu icon button for the simple layout header.
templ SimpleMenuButton(labels *i18n.Labels) {
	<div>
		<button
			id="menu-button"
			aria-label={ labels.Navbar }
			title={ labels.Navbar }
			class="cursor-pointer p-1 rounded hover:bg-hover transition-colors"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="h-5 w-5 text-foreground"
				id="menu-icon"
			>
				<path d="M4 5h16"></path>
				<path d="M4 12h16"></path>
				<path d="M4 19h16"></path>
			</svg>
		</button>
	</div>
}

// SimpleMenu renders the full-screen overlay navbar menu for the simple layout.
templ SimpleMenu(data *PageData) {
	<div
		class="fixed inset-0 z-40 bg-background pb-4 hidden overflow-scroll p-4 md:p-0"
		id="menu-wrapper"
	>
		<nav
			class="max-w-prose mx-auto w-full rounded-xl border border-sidebar-border p-6 mt-20 md:mt-24"
		>
			<ul>
				if data.Site.NavbarRoot != nil {
					@Navbar(data.Site.NavbarRoot.Children, data.Site.FlatURLs)
				}
			</ul>
		</nav>
		<footer class="p-6 text-sm text-center item-end">
			{ data.Site.Labels.GeneratedWith }
			<a href="https://kiln.talesign.com" target="_blank" class="underline">Kiln</a>
			{ " • " }
			<a href="https://github.com/otaleghani/kiln" target="_blank" class="underline">Github</a>
		</footer>
	</div>
}

// BackToTop renders a fixed "back to top" button with an animated SVG arrow.
templ BackToTop(labels *i18n.Labels) {
	<button id="back-to-top" class="back-to-top" aria-label={ labels.BackToTop } title={ labels.BackToTop }>
		<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="m18 15-6-6-6 6"></path>
		</svg>
	</button>
}

// tableRow renders a single row in the base table view.
templ tableRow(data *PageData, note *obsidian.File) {
	<tr class="hover:bg-hover transition-colors">
		for _, col := range data.Base.Columns {
			<td class="px-3 py-2 border-b border-r border-sidebar-border align-top leading-snug last:border-r-0 empty:bg-foreground/5">
				if col == "file.name" {
					<a
						href={ templ.SafeURL(note.WebPath) }
						class="text-accent font-medium no-underline hover:underline"
					>{ note.Name }</a>
				} else {
					if data.Base.ValueFn != nil {
						if val := data.Base.ValueFn(note, col); val != "" {
							<div class="[&_ul]:pl-5">
								@templ.Raw(val)
							</div>
						}
					}
				}
			</td>
		}
	</tr>
}

// cardItem renders a single card in the base cards view.
templ cardItem(data *PageData, note *obsidian.File) {
	<div class="bg-background border border-sidebar-border rounded-lg p-4 shadow-sm flex flex-col transition-all duration-100 ease-in-out hover:-translate-y-0.5 hover:shadow-md hover:border-accent">
		<div class="text-lg font-bold mb-3 border-b border-sidebar-border pb-2">
			<a
				href={ templ.SafeURL(note.WebPath) }
				class="text-foreground no-underline hover:text-accent hover:underline"
			>{ note.Name }</a>
		</div>
		<div class="flex flex-col gap-1.5">
			for _, col := range data.Base.Columns {
				if col != "file.name" {
					<div class="flex flex-col text-sm leading-snug">
						<span class="text-foreground/60 font-medium">
							{ col }
						</span>
						<span class="text-foreground break-words">
							if data.Base.ValueFn != nil {
								if val := data.Base.ValueFn(note, col); val != "" {
									@templ.Raw(val)
								} else {
									<span class="text-sidebar-border">-</span>
								}
							} else {
								<span class="text-sidebar-border">-</span>
							}
						</span>
					</div>
				}
			}
		</div>
	</div>
}

// listItem renders a single item in the base list view.
templ listItem(data *PageData, note *obsidian.File) {
	<li class="flex justify-between items-center px-4 py-2.5 border-b border-sidebar-border last:border-b-0 transition-colors hover:bg-hover overflow-x-auto">
		<div class="flex-1">
			<a
				href={ templ.SafeURL(note.WebPath) }
				class="font-medium text-foreground text-[0.95em] no-underline hover:text-accent hover:underline"
			>{ note.Name }</a>
		</div>
		<div class="flex gap-2 text-xs ml-4 items-start">
			for _, col := range data.Base.Columns {
				if col != "file.name" {
					if data.Base.ValueFn != nil {
						if val := data.Base.ValueFn(note, col); val != "" {
							<span class="text-nowrap bg-sidebar border border-sidebar-border rounded px-1.5 py-0.5 text-foreground/80 max-w-[150px] truncate">
								@templ.Raw(val)
							</span>
						}
					}
				}
			}
		</div>
	</li>
}
