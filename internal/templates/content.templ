// @feature:layouts Content-type renderers, base view variants, and sidebar components.
package templates

import (
	"fmt"
	"strconv"

	"github.com/otaleghani/kiln/internal/i18n"
	"github.com/otaleghani/kiln/internal/obsidian"
)

// NoteMetaBar renders the reading metadata bar at the top of note content.
templ NoteMetaBar(data *PageData) {
	if data.IsNote && data.Meta != nil {
		<div class="note-meta-bar">
			<div class="note-meta-items">
				<span class="note-meta-item">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"></circle>
						<polyline points="12 6 12 12 16 14"></polyline>
					</svg>
					{ FormatReadingTime(data.Meta.ReadingTime, data.Site.Labels.MinRead) }
				</span>
				<span class="note-meta-item">
					{ strconv.Itoa(data.Meta.WordCount) } { data.Site.Labels.Words }
				</span>
				<span class="note-meta-item">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
						<line x1="16" y1="2" x2="16" y2="6"></line>
						<line x1="8" y1="2" x2="8" y2="6"></line>
						<line x1="3" y1="10" x2="21" y2="10"></line>
					</svg>
					{ data.Site.Labels.Updated } { FormatDate(data.Meta.Modified) }
				</span>
				<span class="note-meta-item">
					<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
						<line x1="16" y1="2" x2="16" y2="6"></line>
						<line x1="8" y1="2" x2="8" y2="6"></line>
						<line x1="3" y1="10" x2="21" y2="10"></line>
					</svg>
					{ data.Site.Labels.Created } { FormatDate(data.Meta.Created) }
				</span>
			</div>
			if len(data.Meta.Tags) > 0 {
				<div class="note-meta-tags">
					for _, tag := range data.Meta.Tags {
						<span class="note-meta-tag">#{ tag }</span>
					}
				</div>
			}
		</div>
	}
}

// ContentNote renders a markdown note.
templ ContentNote(data *PageData) {
	if data.IsNote {
		<div id="content" class="h-dvh overflow-y-auto overflow-x-hidden">
			<div class="p-4 content">
				@NoteMetaBar(data)
				@templ.Raw(data.Content)
			</div>
		</div>
	}
}

// ContentGraph renders the full-page graph view.
templ ContentGraph(data *PageData) {
	if data.IsGraph {
		<div class="canvas-mode" id="content">
			@templ.Raw(data.Content)
		</div>
	}
}

// ContentCanvas renders an Obsidian canvas with inline script injecting CanvasJSON.
templ ContentCanvas(data *PageData) {
	if data.IsCanvas {
		<div class="canvas-mode">
			<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
			<script src={ data.Site.BaseURL + "/canvas.js" }></script>
			<div id="viewport">
				<div id="canvas-world">
					<svg id="edges-layer"></svg>
				</div>
			</div>
			<div id="canvas-controls">
				<button
					onclick="window.renderer.zoomOut()"
					class="canvas-btn icon-minus"
					aria-label="Zoom Out"
				></button>
				<button
					onclick="window.renderer.resetView()"
					class="canvas-btn icon-maximize"
					aria-label="Reset View"
				></button>
				<button
					onclick="window.renderer.zoomIn()"
					class="canvas-btn icon-plus"
					aria-label="Zoom In"
				></button>
			</div>
			@canvasInitScript(data.CanvasJSON)
		</div>
	}
}

// canvasInitScript outputs the inline <script> that boots the canvas renderer.
templ canvasInitScript(canvasJSON string) {
	<div id="canvas-data" hidden data-json={ canvasJSON }></div>
	<script>
		(function() {
			var data = JSON.parse(document.getElementById("canvas-data").getAttribute("data-json"));
			if (window.initCanvasMode) {
				window.initCanvasMode(data);
			} else {
				document.addEventListener('DOMContentLoaded', function() {
					if (window.initCanvasMode) window.initCanvasMode(data);
				});
			}
		})();
	</script>
}

// Content404 renders the 404 not found page.
templ Content404(data *PageData) {
	if data.Is404 {
		<div id="content" class="h-dvh overflow-y-auto overflow-x-hidden">
			<div class="p-4 content flex flex-col items-center justify-center min-h-[60vh]">
				<h1 class="text-6xl font-bold text-foreground mb-4">404</h1>
				<p class="text-xl text-foreground/70 mb-8">{ data.Site.Labels.PageNotFound }</p>
				<a
					href={ templ.SafeURL(data.Site.BaseURL + "/") }
					class="text-accent hover:underline"
				>
					{ data.Site.Labels.GoBackHome }
				</a>
			</div>
		</div>
	}
}

// ContentFolder renders a folder listing with sub-folders and files.
templ ContentFolder(data *PageData) {
	if data.IsFolder && data.Folder != nil {
		<div class="my-4 w-full font-main text-foreground p-4" id="content">
			<h1 class="mt-0 mb-6 text-3xl border-b border-sidebar-border pb-2 text-foreground font-semibold">
				{ data.Site.Labels.Folder } { data.Folder.Name }
			</h1>
			<ul class="list-none p-0 m-0 mb-8 border border-sidebar-border rounded-md bg-background">
				for _, f := range data.Folder.Folders {
					<li class="flex justify-between items-center px-4 py-2.5 border-b border-sidebar-border last:border-b-0 transition-colors hover:bg-hover">
						<div class="flex items-center">
							<span class="mr-2 opacity-70 text-lg">&#128193;</span>
							<a
								href={ templ.SafeURL(f.WebPath) }
								class="font-semibold text-foreground text-[0.95em] no-underline hover:text-accent hover:underline"
							>{ f.Name }</a>
						</div>
					</li>
				}
				for _, f := range data.Folder.Files {
					<li class="flex justify-between items-center px-4 py-2.5 border-b border-sidebar-border last:border-b-0 transition-colors hover:bg-hover">
						<div class="flex items-center">
							<span class="mr-2 opacity-70 text-lg">&#128196;</span>
							<a
								href={ templ.SafeURL(f.WebPath) }
								class="font-medium text-foreground text-[0.95em] no-underline hover:text-accent hover:underline"
							>{ f.Name }</a>
						</div>
						<div class="flex gap-2 text-xs ml-4">
							<span class="text-foreground/60" title="Last Modified">
								{ FormatDate(f.Modified) }
							</span>
						</div>
					</li>
				}
			</ul>
		</div>
	}
}

// ContentTag renders a tag listing with associated files.
templ ContentTag(data *PageData) {
	if data.IsTag && data.Tag != nil {
		<div class="my-4 w-full font-main text-foreground p-4" id="content">
			<h1 class="mt-0 mb-6 text-3xl border-b border-sidebar-border pb-2 text-foreground font-semibold">
				{ data.Site.Labels.Tag } { data.Tag.Name }
			</h1>
			<ul class="list-none p-0 m-0 mb-8 border border-sidebar-border rounded-md bg-background">
				for _, f := range data.Tag.Files {
					<li class="flex justify-between items-center px-4 py-2.5 border-b border-sidebar-border last:border-b-0 transition-colors hover:bg-hover">
						<div class="flex items-center">
							<span class="mr-2 opacity-70 text-lg">&#128196;</span>
							<a
								href={ templ.SafeURL(f.WebPath) }
								class="font-medium text-foreground text-[0.95em] no-underline hover:text-accent hover:underline"
							>{ f.Name }</a>
						</div>
						<div class="flex gap-2 text-xs ml-4">
							<span class="text-foreground/60" title="Last Modified">
								{ FormatDate(f.Modified) }
							</span>
						</div>
					</li>
				}
			</ul>
		</div>
	}
}

// ContentBase dispatches to the appropriate base view (table/cards/list) by ViewType.
templ ContentBase(data *PageData) {
	if data.IsBase {
		<div id="content" class="h-dvh overflow-y-auto">
			if data.Base.ViewType == "table" {
				@BaseTable(data)
			}
			if data.Base.ViewType == "cards" {
				@BaseCards(data)
			}
			if data.Base.ViewType == "list" {
				@BaseList(data)
			}
		</div>
	}
}

// BaseTable renders a database-style table view.
templ BaseTable(data *PageData) {
	<div class="w-full font-main text-foreground">
		<div class="overflow-x-auto border-b border-b-sidebar-border bg-background mb-4">
			<table class="w-full border-collapse border-spacing-0 text-sm">
				<thead>
					<tr class="w-full">
						for _, col := range data.Base.Columns {
							<th class="bg-sidebar text-foreground font-semibold text-left px-3 py-2.5 border-b border-r border-sidebar-border whitespace-nowrap last:border-r-0">
								if data.Base.DisplayNameFn != nil {
									{ data.Base.DisplayNameFn(col) }
								} else {
									{ col }
								}
							</th>
						}
					</tr>
				</thead>
				<tbody class="w-full">
					if len(data.Base.Groups) > 0 {
						for _, group := range data.Base.Groups {
							<tr class="group-row">
								<td
									colspan={ strconv.Itoa(len(data.Base.Columns)) }
									class="bg-sidebar text-foreground font-bold text-[0.95em] px-3 py-2 text-left border-b border-sidebar-border"
								>
									{ group.Key }
									<span class="font-normal opacity-70 text-sm ml-1">
										{ fmt.Sprintf("(%d)", len(group.Notes)) }
									</span>
								</td>
							</tr>
							for _, note := range group.Notes {
								@tableRow(data, note)
							}
						}
					} else {
						for _, note := range data.Base.Notes {
							@tableRow(data, note)
						}
					}
				</tbody>
			</table>
		</div>
	</div>
}

// BaseCards renders a card grid view.
templ BaseCards(data *PageData) {
	<div class="my-4 w-full font-main text-foreground p-4 overflow-y-auto">
		if len(data.Base.Groups) > 0 {
			for _, group := range data.Base.Groups {
				<div class="mb-6">
					<h3 class="mb-3 font-bold text-lg border-b border-sidebar-border pb-1">
						{ group.Key }
						<span class="font-normal opacity-70 text-sm ml-1">
							{ fmt.Sprintf("(%d)", len(group.Notes)) }
						</span>
					</h3>
					<div
						class="grid gap-4 mb-8"
						style="grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));"
					>
						for _, note := range group.Notes {
							@cardItem(data, note)
						}
					</div>
				</div>
			}
		} else {
			<div
				class="grid gap-4 mb-8"
				style="grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));"
			>
				for _, note := range data.Base.Notes {
					@cardItem(data, note)
				}
			</div>
		}
	</div>
}

// BaseList renders a list view.
templ BaseList(data *PageData) {
	<div class="p-4 w-full font-main text-foreground">
		if len(data.Base.Groups) > 0 {
			for _, group := range data.Base.Groups {
				<div class="mb-6">
					<h3 class="mb-3 font-bold text-lg border-b border-sidebar-border pb-1">
						{ group.Key }
						<span class="font-normal opacity-70 text-sm ml-1">
							{ fmt.Sprintf("(%d)", len(group.Notes)) }
						</span>
					</h3>
					<ul class="list-none p-0 m-0 mb-8 border border-sidebar-border rounded-md bg-background">
						for _, note := range group.Notes {
							@listItem(data, note)
						}
					</ul>
				</div>
			}
		} else {
			<ul class="list-none p-0 m-0 mb-8 border border-sidebar-border rounded-md bg-background">
				for _, note := range data.Base.Notes {
					@listItem(data, note)
				}
			</ul>
		}
	</div>
}

// LocalGraph renders the local graph expand button and container for the default layout sidebar.
templ LocalGraph(disabled bool, labels *i18n.Labels) {
	if !disabled {
		<div id="local-graph-wrapper" class="p-4 border-b border-b-sidebar-border">
			<header class="flex justify-between items-center py-2">
				<span class="font-bold">{ labels.LocalGraph }</span>
				<div>
					<button
						class="cursor-pointer p-1 rounded hover:bg-hover transition-colors"
						onclick="window.toggleGraphExpand()"
						title={ labels.Expand }
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							width="24"
							height="24"
							viewBox="0 0 24 24"
							fill="none"
							stroke="currentColor"
							stroke-width="2"
							stroke-linecap="round"
							stroke-linejoin="round"
							class="w-5 h-5"
						>
							<path d="M15 3h6v6"></path>
							<path d="m21 3-7 7"></path>
							<path d="m3 21 7-7"></path>
							<path d="M9 21H3v-6"></path>
						</svg>
					</button>
				</div>
			</header>
			<div
				id="local-graph-container"
				class="rounded border border-sidebar-border aspect-square"
			></div>
		</div>
	}
}

// TOCPanel renders the "On this page" table of contents for the default layout sidebar.
templ TOCPanel(data *PageData) {
	if !data.Site.DisableTOC {
		<div id="toc-container" hx-swap-oob="true">
			if data.TOC != "" {
				<header class="flex justify-between items-center py-2 border-b border-sidebar-border mb-4">
					<span class="font-bold">{ data.Site.Labels.OnThisPage }</span>
				</header>
				<div>
					@templ.Raw(data.TOC)
				</div>
			}
		</div>
	}
}

// BacklinksPanel renders the backlinks section for the default layout sidebar.
templ BacklinksPanel(data *PageData) {
	if !data.Site.DisableBacklinks && len(data.Backlinks) > 0 {
		<div id="backlinks-container" hx-swap-oob="true">
			<header class="flex justify-between items-center py-2 border-b border-sidebar-border mb-4">
				<span class="font-bold">{ data.Site.Labels.Backlinks }</span>
			</header>
			<ul class="flex flex-col gap-1">
				for _, bl := range data.Backlinks {
					<li>
						<a
							href={ templ.SafeURL(bl.WebPath) }
							hx-get={ string(templ.SafeURL(bl.WebPath)) }
							hx-target="#kiln-main"
							hx-select="#kiln-main"
							hx-swap="outerHTML"
							hx-push-url="true"
							class="text-sm hover:text-accent transition-colors"
						>
							{ bl.Name }
						</a>
					</li>
				}
			</ul>
		</div>
	}
}

// SimpleSearchButton renders the search icon button for the simple layout header.
templ SimpleSearchButton(labels *i18n.Labels) {
	<div>
		<button
			id="search-button"
			aria-label={ labels.Search }
			title={ labels.Search }
			onclick="if(window.openSearchModal)window.openSearchModal()"
			class="cursor-pointer p-1 rounded hover:bg-hover transition-colors"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				stroke-linejoin="round"
				class="h-5 w-5 text-foreground"
				id="search-icon"
			>
				<circle cx="11" cy="11" r="8"></circle>
				<path d="m21 21-4.3-4.3"></path>
			</svg>
		</button>
	</div>
}

